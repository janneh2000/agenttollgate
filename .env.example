# --- Locus / CheckoutWithLocus -----------------------------------------
# Sign up at https://beta.paywithlocus.com (invite code: BETA-ACCESS-DOCS)
# and paste your secret key here. The wrapper supports a "mock mode" if
# left blank — perfect for demos without burning real USDC.
LOCUS_API_KEY=
LOCUS_API_BASE=https://beta-api.paywithlocus.com
LOCUS_MERCHANT_ID=
LOCUS_WEBHOOK_SECRET=replace-me-with-shared-secret

# --- App ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_PATH=./data/agenttollgate.db

# --- Optional: enable the demo's seed data on first boot ---------------
SEED_ON_BOOT=true
